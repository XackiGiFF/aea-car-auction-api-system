NODE_ENV=production
PORT=3000

DB_HOST=api_mariadb
DB_PORT=3306
DB_USER=aea_user
DB_PASSWORD=change_me
DB_NAME=aea_api

# Upstream API (AJES)
API_BASE_URL=http://87.242.72.57/api/

API_IP=
API_CODE=
API_BARRIER_CODE=

AJES_CAR_TOKEN=
AJES_BIKE_TOKEN=
AJES_CAR_TOKEN_CNY=
AJES_CAR_TOKEN_JPY=
AJES_CAR_TOKEN_KRW=

# On-demand calculation via calc-bot internal API
ON_DEMAND_CALC_ENABLED=true
ON_DEMAND_CALC_TIMEOUT_MS=12000
CALC_BOT_URL=http://calc-bot:3001
# Must match calc-bot CALC_BOT_INTERNAL_TOKEN
CALC_BOT_INTERNAL_TOKEN=change_me_internal_token

# API hardening
API_PAGINATION_LIMIT_DEFAULT=20
API_PAGINATION_LIMIT_MAX=200
API_PAGINATION_OFFSET_MAX=1000000
API_FILTER_STRING_MAX_LEN=120
# Cache TTL for AJES /filters/dynamic responses (ms)
AJES_DYNAMIC_FILTERS_CACHE_TTL_MS=60000
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=240

# Optional swagger server URL override
SWAGGER_SERVER_URL=http://localhost:3000
