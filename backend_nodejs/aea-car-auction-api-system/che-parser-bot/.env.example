NODE_ENV=production
PORT=3003

DB_HOST=api_mariadb
DB_PORT=3306
DB_USER=aea_user
DB_PASSWORD=change_me
DB_NAME=aea_api

API_BASE_URL=http://api-gateway:3000

# Optional local media mirror (recommended for che168 to avoid hotlink 403)
CHE_MEDIA_DOWNLOAD_ENABLED=false
CHE_MEDIA_ROOT=/app/media
CHE_MEDIA_BASE_URL=https://asiaexpressauto.ru/cdn/media

# Preferred mode: use dedicated media microservice
MEDIA_SERVICE_URL=http://cdn-media-bot:3010
MEDIA_SERVICE_TOKEN=change_me_long_random_token
MEDIA_SERVICE_TIMEOUT_MS=25000

# Cleanup behavior for stale cars and media
PURGE_DELETED_ENABLED=true
PURGE_DELETED_AFTER_HOURS=48
PURGE_DELETED_BATCH_SIZE=5000

# Puppeteer retry behavior for transient network failures
CHE_PUPPETEER_MAX_ATTEMPTS=3
CHE_PUPPETEER_RETRY_DELAY_MS=5000
CHE_PUPPETEER_RETRY_MAX_DELAY_MS=30000
CHE_PUPPETEER_NAV_TIMEOUT_MS=60000

# Optional AI fallback for brand/model translation
# If DEEPSEEK_ENABLED is omitted, parser enables AI automatically when DEEPSEEK_API_KEY is set.
DEEPSEEK_ENABLED=false
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=12000
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_RETRY_DELAY_MS=1500
